{
  "ConnectionStrings": {
    "DefaultConnection": "Host=localhost;Port=5432;Database=anime;Username=animeuser;Password=${DB_PASSWORD};"
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "HikariCPOptions": {
    "MinimumIdle": 10,
    "MaximumPoolSize": 100,
    "ConnectionTimeout": 30,
    "IdleTimeout": 300,
    "MaxLifetime": 1800
  },
  "EnableDetailedErrors": true,
  "FactoryResetInterval": 1440
}